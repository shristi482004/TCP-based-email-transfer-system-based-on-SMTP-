# MongoDB connection string (from MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mailsim?retryWrites=true&w=majority

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The callback URL registered in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session secret - use a long random string
SESSION_SECRET=change_this_to_a_long_random_secret_string_please

# Server port
PORT=3000

# App base URL
APP_URL=http://localhost:3000
